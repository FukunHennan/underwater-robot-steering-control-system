---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    lineColor: "#555"
---
flowchart TD
    subgraph APP["应用层"]
        direction LR
        DEMO["demo.c\n主程序逻辑"]
        MAIN["main.c\n系统入口"]
    end

    subgraph BSP["板级支持包 (BSP)"]
        direction LR
        MODBUS_D["modbus.c/.h\nModbus RTU 从站\n寄存器管理"]
        ADC_D["adc.c/.h\nADC 数据采集\n模拟输入/电压"]
        PWM_D["pwm.c/.h\nPWM 控制\n舵机/LED"]
        MS901M_D["atk_ms901m.c/.h\nIMU 姿态传感器\n9轴数据"]
        GPIO_D["gpio.c/.h\nGPIO 扩展\n4路IO"]
    end

    subgraph MIDDLEWARE["中间件"]
        direction LR
        FREEMODBUS["FreeModbus\nModbus 协议栈"]
        SYSTEM["SYSTEM\nusart / delay / sys"]
    end

    subgraph HAL["硬件抽象层 (HAL)"]
        direction LR
        HAL_ADC["HAL_ADC"]
        HAL_TIM["HAL_TIM"]
        HAL_UART["HAL_UART"]
        HAL_GPIO["HAL_GPIO"]
    end

    subgraph HW["硬件 STM32F407VET6"]
        direction LR
        ADC1_H["ADC1"]
        TIM_H["TIM1/3/4/8"]
        USART_H["USART1/2/3"]
        GPIO_H["GPIO"]
    end

    MAIN --> DEMO
    DEMO --> MODBUS_D
    DEMO --> ADC_D
    DEMO --> PWM_D
    DEMO --> MS901M_D
    MODBUS_D --> FREEMODBUS
    MODBUS_D --> ADC_D
    MODBUS_D --> PWM_D
    MS901M_D --> SYSTEM
    FREEMODBUS --> HAL_UART
    ADC_D --> HAL_ADC
    PWM_D --> HAL_TIM
    MS901M_D --> HAL_UART
    GPIO_D --> HAL_GPIO
    SYSTEM --> HAL_UART
    HAL_ADC --> ADC1_H
    HAL_TIM --> TIM_H
    HAL_UART --> USART_H
    HAL_GPIO --> GPIO_H
