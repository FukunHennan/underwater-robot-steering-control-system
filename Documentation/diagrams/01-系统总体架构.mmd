---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    primaryBorderColor: "#2C5F8A"
    lineColor: "#555"
    secondaryColor: "#F0F4F8"
    tertiaryColor: "#E8F5E9"
---
flowchart TB
    subgraph POWER["⚡ 电源系统"]
        direction LR
        BAT["外部电源\n(电池/适配器)"]
        LM2596["LM2596S-ADJ\n降压模块"]
        AMS1117["AMS1117-3.3\n稳压芯片"]
        BAT --> LM2596
        BAT --> AMS1117
        LM2596 -->|"舵机/电调供电"| SERVO_PWR((" "))
        AMS1117 -->|"3.3V"| MCU_PWR((" "))
    end

    subgraph MCU["🔧 主控单元 STM32F407VET6"]
        direction TB
        CPU["ARM Cortex-M4\n168MHz / 512KB Flash / 192KB SRAM"]

        subgraph PERIPHERALS["片上外设"]
            direction LR
            USART1["USART1\n调试串口\n115200"]
            USART2["USART2\nModbus RTU\n9600 8N1"]
            USART3["USART3\nMS901M\n115200"]
            ADC1["ADC1\n5通道 12bit"]
            TIM1["TIM1\nLED PWM ×2"]
            TIM34["TIM3/TIM4\n舵机 PWM ×6"]
            TIM8["TIM8\n舵机 PWM ×2"]
            GPIO_P["GPIO ×4\n扩展接口"]
        end
    end

    subgraph SENSORS["📡 传感器"]
        direction TB
        MS901M["ATK-MS901M\n九轴姿态传感器\nRoll/Pitch/Yaw\nGyro/Accel/Mag"]
        AIN["模拟输入 ×4\n信号采集"]
        VDET["电压检测电路\nLM321 + 分压"]
    end

    subgraph ACTUATORS["⚙️ 执行器"]
        direction TB
        SERVOS["舵机/电调 ×8\n500~2500μs\n50Hz PWM"]
        LEDS["LED灯板 ×2\n占空比 0~1000"]
    end

    subgraph HOST["💻 上位机监控系统"]
        direction TB
        BROWSER["Chrome/Edge 浏览器"]
        WEBAPP["React + Vite\nWeb Serial API"]
        DASHBOARD["监控仪表盘\n姿态 / PWM / ADC / 3D模型"]
        BROWSER --> WEBAPP --> DASHBOARD
    end

    %% Connections
    MS901M <-->|"UART 115200"| USART3
    AIN -->|"模拟信号"| ADC1
    VDET -->|"模拟信号"| ADC1
    TIM34 -->|"PWM"| SERVOS
    TIM8 -->|"PWM"| SERVOS
    TIM1 -->|"PWM"| LEDS
    USART2 <-->|"Modbus RTU\n9600 8N1"| HOST
    USART1 -->|"调试输出"| PC_DEBUG["调试终端"]
    MCU_PWR --> MCU
    SERVO_PWR --> ACTUATORS
