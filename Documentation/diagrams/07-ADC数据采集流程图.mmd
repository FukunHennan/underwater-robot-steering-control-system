---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    lineColor: "#555"
---
flowchart TD
    START(["modbus_update_sensors()\n每次主循环调用"]) --> TICK["更新系统时钟\nSYS_TICK_L/H = HAL_GetTick()"]

    TICK --> AIN_LOOP{{"模拟输入通道 CH0~CH3"}}
    AIN_LOOP --> AIN_READ["adc_get_channel_average(ch, 10)\n10次采样取平均"]
    AIN_READ --> AIN_CONV["数据转换处理"]
    AIN_CONV --> AIN_REG["写入寄存器\nANALOG_x = (int16)\n模拟量数据"]
    AIN_REG --> AIN_LOOP

    AIN_LOOP -->|"完成"| VOL_CH["电压检测通道 CH4"]
    VOL_CH --> VOL_READ["adc_get_power_voltage()"]
    VOL_READ --> VOL_AVG["10次平均 → 电压值"]
    VOL_AVG --> VOL_DIV["乘以分压比\nV_power = V_adc × 3.0"]
    VOL_DIV --> VOL_REG["写入寄存器\nVOLTAGE = (uint16)(V × 100)"]

    VOL_REG --> RAW_LOOP{{"原始值 CH0~CH4"}}
    RAW_LOOP --> RAW_READ["adc_get_channel_value(ch)\n单次 ADC 转换"]
    RAW_READ --> RAW_REG["写入寄存器\nADC_RAW_x = 12bit 值 (0~4095)"]
    RAW_REG --> RAW_LOOP
    RAW_LOOP -->|"完成"| DONE(["传感器寄存器更新完成"])
