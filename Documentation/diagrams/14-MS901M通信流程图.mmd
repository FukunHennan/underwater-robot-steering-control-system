---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    lineColor: "#555"
---
flowchart TD
    START(["主循环每 5ms"])

    START --> ATT_REQ["atk_ms901m_get_attitude(&att, 5)\n读取姿态数据 (超时 5ms)"]
    ATT_REQ --> ATT_OK{读取成功?}

    ATT_OK -->|"是"| ATT_PARSE["解析数据帧\nFrame ID = 0x01"]
    ATT_PARSE --> ATT_DATA["提取 Roll / Pitch / Yaw\nint16 → float (÷32768×180°)"]
    ATT_DATA --> ATT_REG["写入 Modbus 浮点寄存器\nmodbus_set_register_float()\nREG_ROLL  = 0x0010\nREG_PITCH = 0x0012\nREG_YAW   = 0x0014"]

    ATT_OK -->|"否 (超时)"| GYRO_REQ

    ATT_REG --> GYRO_REQ["atk_ms901m_get_gyro(&gyro, NULL, 5)\n读取陀螺仪数据 (超时 5ms)"]
    GYRO_REQ --> GYRO_OK{读取成功?}

    GYRO_OK -->|"是"| GYRO_PARSE["解析数据帧\nFrame ID = 0x03"]
    GYRO_PARSE --> GYRO_DATA["提取 Gyro X / Y / Z\nint16 → float (÷32768×2000°/s)"]
    GYRO_DATA --> GYRO_REG["写入 Modbus 浮点寄存器\nREG_GYRO_X = 0x0016\nREG_GYRO_Y = 0x0018\nREG_GYRO_Z = 0x001A"]

    GYRO_OK -->|"否 (超时)"| DONE
    GYRO_REG --> DONE(["继续主循环"])

    subgraph UART["USART3 通信参数"]
        direction LR
        PARAM["波特率: 115200\n数据位: 8\n校验: 无\n停止位: 1"]
        FRAME["帧格式:\n帧头 0x55 0xAF\n| Frame ID | 数据长度 |\n| 数据区 | 校验和 |"]
    end
