---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    lineColor: "#555"
---
flowchart LR
    subgraph IEEE754["IEEE 754 单精度浮点 (32-bit)"]
        direction LR
        SIGN["符号位\n1 bit\n[31]"]
        EXP["指数位\n8 bit\n[30:23]"]
        MANT["尾数位\n23 bit\n[22:0]"]
    end

    subgraph MODBUS["Modbus 寄存器存储 (Big-Endian 字序)"]
        direction TB
        REG_H["寄存器 addr\n高 16 位\nBit[31:16]"]
        REG_L["寄存器 addr+1\n低 16 位\nBit[15:0]"]
    end

    subgraph EXAMPLE["示例: Roll = 45.5°"]
        direction TB
        HEX["float 45.5 = 0x42360000"]
        H16["REG[addr]   = 0x4236"]
        L16["REG[addr+1] = 0x0000"]
    end

    IEEE754 --> MODBUS
    MODBUS --> EXAMPLE
