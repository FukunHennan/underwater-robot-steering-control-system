---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    lineColor: "#555"
---
flowchart LR
    MCU["STM32F407VET6\n主控芯片"]

    subgraph U1["USART1 — 调试串口"]
        direction TB
        U1_CFG["波特率: 115200\n引脚: PA9(TX) PA10(RX)"]
        U1_FUNC["功能:\nprintf 调试输出\n系统状态打印\n错误日志"]
    end

    subgraph U2["USART2 — Modbus 通信"]
        direction TB
        U2_CFG["波特率: 9600  8N1\n引脚: PA2(TX) PA3(RX)"]
        U2_FUNC["功能:\nModbus RTU 从站\nFreeModbus 协议栈\n上位机数据交互"]
    end

    subgraph U3["USART3 — 姿态传感器"]
        direction TB
        U3_CFG["波特率: 115200\n引脚: PB10(TX) PB11(RX)"]
        U3_FUNC["功能:\nATK-MS901M 通信\n姿态/陀螺仪数据\n自定义帧协议"]
    end

    MCU --> U1
    MCU --> U2
    MCU --> U3

    U1 -->|"USB-TTL"| PC["PC 调试终端"]
    U2 -->|"RS-485 / TTL"| MASTER["Modbus 主站\n(Web Dashboard)"]
    U3 -->|"TTL 3.3V"| IMU["ATK-MS901M\n九轴 IMU"]
