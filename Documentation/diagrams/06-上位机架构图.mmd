---
config:
  theme: base
  themeVariables:
    primaryColor: "#4A90D9"
    primaryTextColor: "#000"
    lineColor: "#555"
---
flowchart TD
    subgraph BROWSER["Chrome / Edge 浏览器"]
        direction TB
        subgraph UI["React UI 层 (App.tsx)"]
            direction LR
            HEADER["顶部栏\n连接状态 / 轮询控制"]
            SYS_PANEL["系统状态面板\nID/版本/模式/故障/时间"]
            ATT_PANEL["姿态数据面板\nRoll/Pitch/Yaw\nGyro X/Y/Z"]
            MODEL_3D["3D姿态模型\nCSS 3D Transform\n实时旋转"]
            PWM_PANEL["PWM控制面板\n8路舵机滑条\n2路LED滑条"]
            ADC_PANEL["ADC数据面板\n4路模拟量原始值\n电压检测值"]
            LOG_PANEL["通信日志面板\nTX/RX Hex帧"]
        end

        subgraph MODBUS_LIB["Modbus RTU 客户端 (modbus.ts)"]
            direction TB
            QUEUE["事务队列\n(异步FIFO串行化)"]
            CRC["CRC16 校验\n(查表法)"]
            FRAME["帧构建/解析\nFC03 / FC06 / FC10"]
            FLOAT["IEEE 754\n浮点转换"]
            QUEUE --> TRANSACT["transact()\n发送帧 → 收集响应"]
            TRANSACT --> CRC
            TRANSACT --> FRAME
            FRAME --> FLOAT
        end

        WEB_SERIAL["Web Serial API\nnavigator.serial"]
    end

    subgraph DEVICE["STM32F407 设备"]
        SLAVE["Modbus RTU 从站\n0x01 / 9600 / 8N1"]
    end

    %% Data flow
    UI -->|"读取请求\n(轮询/手动)"| QUEUE
    UI -->|"写入请求\n(滑条释放)"| QUEUE
    TRANSACT <-->|"串口读写"| WEB_SERIAL
    WEB_SERIAL <-->|"USB转串口"| SLAVE

    %% Feedback
    TRANSACT -->|"响应数据"| UI
    TRANSACT -->|"帧日志"| LOG_PANEL
