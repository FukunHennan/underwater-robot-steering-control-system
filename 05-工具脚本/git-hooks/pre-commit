#!/bin/sh
# =============================================================================
# pre-commit hook: Wiki 同步拦截器
# -----------------------------------------------------------------------------
# 当本次提交包含代码/文档改动 (Software/, Documentation/) 但未同步改动 Wiki/ 时,
# 阻止提交并提示。跳过方式:
#   - git commit --no-verify
#   - commit message 含 [no-wiki] 或 [skip-wiki]
# =============================================================================

# 获取本次 staged 的文件
staged=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged" ]; then
  exit 0
fi

# 是否有代码/文档改动 (Wiki 自己不算)
has_impact=$(echo "$staged" | grep -E '^(Software/|Documentation/)' | grep -v '^Wiki/')
has_wiki=$(echo "$staged" | grep -E '^Wiki/')

# 没代码/文档改动则放行
if [ -z "$has_impact" ]; then
  exit 0
fi

# 有代码改动 + 有 Wiki 改动 -> 放行
if [ -n "$has_wiki" ]; then
  exit 0
fi

# 检查 commit message 是否含跳过标记
msg_file="$1"
if [ -z "$msg_file" ]; then
  msg_file=".git/COMMIT_EDITMSG"
fi
if [ -f "$msg_file" ]; then
  if grep -qE '\[(no-wiki|skip-wiki)\]' "$msg_file"; then
    exit 0
  fi
fi

# 拦截
cat <<EOF

=============================================================
  [pre-commit] 拦截: 检测到代码/文档改动但 Wiki 未同步
=============================================================

本次 staged 的代码/文档文件:
$(echo "$has_impact" | sed 's/^/  - /')

请在本次提交中同步更新 Wiki:
  - Wiki/entities/*.md    (对应实体)
  - Wiki/health-check-log.md  (体检记录)

跳过方式 (仅在确实无需同步时使用):
  1. git commit --no-verify
  2. 在 commit message 中加入  [no-wiki]  或  [skip-wiki]

=============================================================

EOF

exit 1
